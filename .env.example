# Capital.com API Configuration
# Required for backtester and live trading

CAPITAL_API_KEY=your_api_key_here
CAPITAL_IDENTIFIER=your_identifier_here
CAPITAL_PASSWORD=your_password_here
CAPITAL_ENVIRONMENT=demo  # Use "demo" for testing, "live" for real trading

# Webhook Configuration
WEBHOOK_API_KEY=random_32_character_string_here
WEBHOOK_SIGNATURE_SECRET=optional_webhook_signature_secret

# Optional: Ntfy.sh Notification (for alerts)
NTFY_TOPIC=trading_alerts_optional
