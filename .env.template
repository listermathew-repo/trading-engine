# Capital.com API credentials
# Obtain from: Capital.com platform → Settings → API Integrations
CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=your_email@example.com
CAPITAL_PASSWORD=your_trading_password

# demo  = Capital.com demo account (paper trading — safe for testing)
# live  = real-money account (only after end-to-end demo verification)
CAPITAL_ENVIRONMENT=demo

# ntfy.sh push notification topic (must match your TradingView alerts setup)
NTFY_TOPIC=Mathew-Trading-Alerts

# SIMULATE_TRADES=true → webhook is received and ntfy fires, but NO order is sent to broker
# Set to false only when you are ready for live automated execution
SIMULATE_TRADES=true

# Webhook API key for authentication
# Generate a random 32-character key and set this value
# TradingView alerts must include: X-API-Key: <your_key>
WEBHOOK_API_KEY=generate_random_32_char_key_here
